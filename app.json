{
  "expo": {
    "name": "Starlyvia",
    "slug": "starlyvia",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "starlyvia",
    "icon": "./assets/app-icon.png",
    "splash": {
      "image": "./assets/illustrations/launch-mark.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C1511"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.starlyvia.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/illustrations/launch-mark.png",
        "backgroundColor": "#142019"
      },
      "package": "com.starlyvia.mobile"
    },
    "androidStatusBar": {
      "backgroundColor": "#0C1511",
      "barStyle": "light-content"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
